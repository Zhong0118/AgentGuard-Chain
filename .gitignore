# ==========================================
# 操作系统与系统缓存 (OS & System Files)
# ==========================================
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# WSL / Linux 临时文件
*~
.fuse_hidden*
.directory

# ==========================================
# 编程语言与开发环境 (Python & Conda)
# ==========================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# 虚拟环境 (Virtual Environments)
.venv/
venv/
env/
ENV/
conda-env/
# 如果你在项目内创建了特定的 conda 环境，请在此处添加其目录名

# Jupyter Notebook 缓存
.ipynb_checkpoints

# pip 编译与打包缓存
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ==========================================
# 编辑器与IDE (IDE & Editors)
# ==========================================
# VS Code
.vscode/
!.vscode/extensions.json
*.code-workspace

# JetBrains (PyCharm, CLion 等)
.idea/

# ==========================================
# 知识管理与笔记 (Obsidian & Zotero)
# ==========================================
# Obsidian 核心工作区配置（包含打开的标签页、UI布局等，建议忽略以避免多设备冲突）
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# 如果不想同步 Zotero 自动生成的本地大文件缓存（如 PDF 提取出来的全文索引）
# .zotero/

# ==========================================
# 依赖与日志 (Node.js & Logs)
# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 日志文件
*.log
logs/
log/

# ==========================================
# 敏感信息与本地配置 (Secrets & Local Configs)
# ==========================================
.env
.env.local
.env.*.local
*.secret
*.pem
*.key